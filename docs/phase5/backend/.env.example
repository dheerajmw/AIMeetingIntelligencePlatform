GROQ_API_KEY=

# Production (Fly.io / Oracle VM / Render / Railway / Docker)
# PORT=8002
# Oracle / Render disk: STORAGE_ROOT=/var/data/storage  DATABASE_URL=sqlite:////var/data/app.db
# Railway volume: STORAGE_ROOT=/data/storage  DATABASE_URL=sqlite:////data/app.db
# CORS_ORIGINS=https://your-frontend.example.com
# WHISPER_MODEL=tiny
# REDIS_URL=redis://...

# Auth (Phase 5)
JWT_SECRET=change-me-in-production
DEV_AUTH_ENABLED=true
AUTH_DISABLED=false

# Optional: encrypt uploads at rest (Fernet key or any passphrase)
# ENCRYPTION_KEY=

# Workspace defaults
DEFAULT_DATA_REGION=us-east-1
DEFAULT_RETENTION_DAYS=90
DEFAULT_MAX_MEETINGS_PER_MONTH=100
DEFAULT_MAX_LLM_TOKENS_PER_MONTH=500000

# Integrations — stub mode simulates Jira/Slack/etc. without API keys (default: true for local dev)
INTEGRATIONS_STUB_MODE=true
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=
# LINEAR_API_KEY=
# LINEAR_TEAM_ID=
# TRELLO_API_KEY=
# TRELLO_TOKEN=
# TRELLO_LIST_ID=
# SLACK_WEBHOOK_URL=
# SMTP_HOST=
# SMTP_FROM=
# SMTP_TO=

# OIDC SSO (optional — production)
# OIDC_ISSUER=https://your-idp.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://127.0.0.1:5175/auth/callback
